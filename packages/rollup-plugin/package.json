{
  "name": "@mdscript/rollup-plugin",
  "version": "0.2.0",
  "description": "Rollup plugin for importing MDS templates as ES modules",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dean0x/mdscript.git",
    "directory": "packages/rollup-plugin"
  },
  "homepage": "https://github.com/dean0x/mdscript#readme",
  "bugs": "https://github.com/dean0x/mdscript/issues",
  "keywords": [
    "mds",
    "rollup",
    "rollup-plugin",
    "markdown",
    "template",
    "llm",
    "prompt"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test __test__/*.spec.mjs"
  },
  "dependencies": {
    "@mdscript/bundler-utils": "^0.2.0"
  },
  "peerDependencies": {
    "@mdscript/mds": "^0.2.0",
    "rollup": "^3.0.0 || ^4.0.0"
  },
  "devDependencies": {
    "@mdscript/mds": "file:../mds",
    "@types/node": "^25.9.1",
    "rollup": "^4.61.1",
    "typescript": "^6.0.3"
  }
}
