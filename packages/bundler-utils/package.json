{
  "name": "@mds/bundler-utils",
  "version": "0.1.0",
  "description": "Shared utilities for MDS bundler plugins",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "./dist-cjs/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js",
      "default": "./dist-cjs/index.js"
    },
    "./mds": {
      "types": "./mds.d.ts"
    }
  },
  "files": [
    "dist/",
    "dist-cjs/",
    "mds.d.ts"
  ],
  "scripts": {
    "clean:cjs": "node -e \"require('fs').rmSync('dist-cjs', { recursive: true, force: true })\"",
    "prebuild": "npm run clean:cjs",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && node -e \"require('fs').writeFileSync('dist-cjs/package.json', '{\\\"type\\\":\\\"commonjs\\\"}\\n')\"",
    "test": "node --test __test__/*.spec.mjs"
  },
  "peerDependencies": {
    "@mds/mds": "^0.1.0"
  },
  "devDependencies": {
    "@mds/mds": "file:../mds",
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0"
  }
}
