/target
crates/mds-wasm/pkg/
crates/mds-wasm/pkg-web/
*.node
node_modules/
crates/mds-napi/index.d.ts
crates/mds-napi/package-lock.json
# napi-rs generated staging (created in CI by `napi create-npm-dirs`/`artifacts`)
crates/mds-napi/npm/
crates/mds-napi/artifacts/
packages/*/dist/
packages/*/dist-cjs/

# Example app build output (sources are tracked, builds are not)
examples/*/dist/
examples/*/package-lock.json

# Python bindings (crates/mds-python) build/test artifacts.
# `maturin develop` drops the compiled extension into the source tree; caches and
# venvs are local-only. Sources (.py/.pyi/py.typed) are tracked.
__pycache__/
*.py[cod]
*.so
*.pyd
.pytest_cache/
.mypy_cache/
.venv/
crates/mds-python/dist/

# devflow local state — local-only, not shared via git (reverses ADR-019; see ADR-023)
.devflow/
