      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl",
      "x86_64-pc-windows-msvc"
    ]
  },
  "files": [
    "index.js",
    "index.d.ts",
    "LICENSE",
    "README.md"
  ],
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0",
    "js-yaml": "4.2.0"
