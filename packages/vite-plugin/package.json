{
  "name": "@mds/vite-plugin",
  "version": "0.1.0",
  "description": "Vite plugin for importing MDS templates as ES modules",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "NODE_ENV=test node --test __test__/*.spec.mjs"
  },
  "dependencies": {
    "@mds/bundler-utils": "^0.1.0"
  },
  "peerDependencies": {
    "@mds/mds": "^0.1.0",
    "vite": "^5.0.0 || ^6.0.0"
  },
  "devDependencies": {
    "@mds/mds": "file:../mds",
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "vite": "^6.0.0"
  }
}
