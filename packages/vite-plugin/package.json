{
  "name": "@mdscript/vite-plugin",
  "version": "0.1.0",
  "description": "Vite plugin for importing MDS templates as ES modules",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dean0x/mds.git",
    "directory": "packages/vite-plugin"
  },
  "homepage": "https://github.com/dean0x/mds#readme",
  "bugs": "https://github.com/dean0x/mds/issues",
  "keywords": ["mds", "vite", "vite-plugin", "markdown", "template", "llm", "prompt"],
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test __test__/*.spec.mjs"
  },
  "dependencies": {
    "@mdscript/bundler-utils": "^0.1.0"
  },
  "peerDependencies": {
    "@mdscript/mds": "^0.1.0",
    "vite": "^5.0.0 || ^6.0.0"
  },
  "devDependencies": {
    "@mdscript/mds": "file:../mds",
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "vite": "^6.0.0"
  }
}
